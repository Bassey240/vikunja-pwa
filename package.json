{
  "name": "vikunja-pwa",
  "version": "0.2.0-alpha",
  "private": true,
  "description": "Unofficial mobile-first Vikunja PWA client with a Node gateway, offline-ready shell, and self-hosted collaboration tools.",
  "license": "AGPL-3.0-only",
  "keywords": [
    "vikunja",
    "pwa",
    "mobile",
    "task-management"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "module",
  "scripts": {
    "dev": "node scripts/start-server.mjs",
    "dev:react": "vite",
    "start": "node scripts/start-server.mjs",
    "docker:local": "./scripts/start-local-docker.sh",
    "docker:local:stop": "docker compose down",
    "build": "vite build",
    "build:react": "vite build",
    "preview": "vite preview",
    "seed:demo": "node scripts/seed-demo-data.mjs",
    "lint": "npm run lint:eslint && npm run lint:syntax",
    "lint:eslint": "eslint .",
    "lint:syntax": "node scripts/check-syntax.mjs",
    "test": "npm run test:smoke",
    "test:smoke": "npm run test:smoke:api && npm run test:smoke:ui",
    "test:smoke:api": "node --test --test-concurrency=1 tests/smoke/api.smoke.test.mjs",
    "test:smoke:ui": "playwright test --config=playwright.config.js",
    "test:smoke:ui:headed": "playwright test --config=playwright.config.js --headed",
    "ci": "npm run lint && npm run build && npm run test:smoke"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "yaml": "^2.8.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
