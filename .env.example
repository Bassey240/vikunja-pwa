# Optional default server for the Settings > Accounts flow.
# If you omit /api/v1, the server will append it automatically.
VIKUNJA_DEFAULT_BASE_URL=http://vikunja.local:3456
APP_PUBLIC_ORIGIN=http://localhost:4300

# Optional HTTPS for mobile/iPhone PWA testing and deployment.
# Notifications and offline shell on iPhone require the installed app to run
# from a trusted HTTPS origin. When both files are set, the app server starts
# with HTTPS and cookies default to Secure=true.
# Put runtime-only certs in ./deploy and point these vars at the mounted paths.
# APP_PUBLIC_ORIGIN=https://localhost:4300
# APP_HTTPS_KEY_PATH=/app/deploy/key.pem
# APP_HTTPS_CERT_PATH=/app/deploy/cert.pem

# Development fallback only - not recommended for production.
# If both are set, the app can still work without logging in from the browser,
# but this is not the intended product path.
# VIKUNJA_BASE_URL=http://vikunja.local:3456
# VIKUNJA_API_TOKEN=tk_replace_me

# Vikunja CLI bridge settings. Needed for admin user management, testmail,
# doctor, and Apply & Restart for writable admin config.
# Same-host Docker:
# VIKUNJA_BRIDGE_MODE=docker-exec
# VIKUNJA_CONTAINER_NAME=vikunja
# VIKUNJA_CLI_PATH=/app/vikunja/vikunja

# SSH to a remote Docker host:
# VIKUNJA_BRIDGE_MODE=ssh-docker-exec
# VIKUNJA_SSH_DESTINATION=admin@vikunja-host
# VIKUNJA_SSH_PORT=22
# VIKUNJA_SSH_KEY_PATH=/app/deploy/id_ed25519
# VIKUNJA_BRIDGE_TIMEOUT_MS=10000

# Comma-separated operator email allowlist for bridge/admin routes.
# Only signed-in Vikunja accounts with a matching email can access them.
# ADMIN_BRIDGE_ALLOWED_EMAILS=office@example.com

# Only needed for docker-exec deployments where this PWA itself runs in Docker
# and must read/write an authoritative Vikunja config source from the host.
# The path below is mounted into the PWA container at
# VIKUNJA_ADMIN_SOURCE_CONTAINER_PATH (default: /app/admin-source).
# For compose-backed setups with relative bind paths in the upstream compose
# file, set VIKUNJA_ADMIN_SOURCE_CONTAINER_PATH to the same absolute path as
# VIKUNJA_ADMIN_SOURCE_HOST_PATH.
# Example:
# VIKUNJA_ADMIN_SOURCE_HOST_PATH=/home/admin/docker/vikunja
# VIKUNJA_ADMIN_SOURCE_CONTAINER_PATH=/home/admin/docker/vikunja
# VIKUNJA_ADMIN_SOURCE_HOST_PATH=/home/admin/docker/vikunja

# Writable SMTP/admin config source.
# If both are unset, SMTP settings stay read-only in the UI and the backend
# only exposes inspection capabilities when the bridge can read effective values.
# File-backed mode:
# - in local docker-exec mode, point this at the mounted in-container path
#   under /app/admin-source
# - in SSH mode, point this at the remote absolute path on the Vikunja host
# VIKUNJA_HOST_CONFIG_PATH=/app/admin-source/config/config.yml
# VIKUNJA_HOST_CONFIG_PATH=/home/admin/docker/vikunja/config/config.yml
# Compose-backed mode:
# - in local docker-exec mode, point this at the mounted in-container path
#   under /app/admin-source
# - in SSH mode, point this at the remote absolute path on the Vikunja host
# - same-host Docker example:
#   VIKUNJA_ADMIN_SOURCE_HOST_PATH=/home/admin/docker/vikunja
#   VIKUNJA_ADMIN_SOURCE_CONTAINER_PATH=/home/admin/docker/vikunja
#   VIKUNJA_COMPOSE_PATH=/home/admin/docker/vikunja/docker-compose.yml
# - SSH example:
#   VIKUNJA_COMPOSE_PATH=/home/admin/docker/vikunja/docker-compose.yml
# VIKUNJA_COMPOSE_PATH=/app/admin-source/docker-compose.yml
# VIKUNJA_COMPOSE_PATH=/home/admin/docker/vikunja/docker-compose.yml

# App session cookie settings.
APP_SESSION_TTL_SECONDS=2592000
APP_SESSION_STORE_PATH=.data/app-sessions.enc
APP_SESSION_KEY_PATH=.data/app-sessions.key
COOKIE_SECURE=
APP_TRUST_PROXY=false
LOG_REQUESTS=true
HEALTHCHECK_UPSTREAM_TIMEOUT_MS=3000
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX=10
SESSION_MUTATION_RATE_LIMIT_WINDOW_SECONDS=60
SESSION_MUTATION_RATE_LIMIT_MAX=30
HOST=0.0.0.0
PORT=4300

# Docker Compose deployment — GID of the docker group on the host.
# Run: getent group docker   (look for the number after the second colon)
DOCKER_GID=999
